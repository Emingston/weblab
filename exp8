CREATE DATABASE eventdb;
USE eventdb;

CREATE TABLE registrations (
  regno VARCHAR(20) PRIMARY KEY,
  name VARCHAR(100),
  events TEXT
);

<!DOCTYPE html>
<html>
<body>

<h2>Event Registration</h2>

<form action="/register" method="POST" onsubmit="return validate()">
  Reg No: <input type="text" name="regno" required><br><br>
  Name: <input type="text" name="name" required><br><br>

  Events:<br>
  <input type="checkbox" name="events" value="Coding Challenge"> Coding Challenge<br>
  <input type="checkbox" name="events" value="Debugging Contest"> Debugging Contest<br>
  <input type="checkbox" name="events" value="Web Design"> Web Design<br>
  <input type="checkbox" name="events" value="Quiz Competition"> Quiz Competition<br>
  <input type="checkbox" name="events" value="Paper Presentation"> Paper Presentation<br><br>

  <button type="submit">Register</button>
</form>

<script>
function validate() {
  let checked = document.querySelectorAll('input[name="events"]:checked');
  if (checked.length > 3) {
    alert("Select maximum 3 events only");
    return false;
  }
  return true;
}
</script>

</body>
</html>

<!DOCTYPE html>
<html>
<body>

<h2>Admin Search</h2>

<form action="/search" method="GET">
  Reg No: <input type="text" name="regno" required>
  <button type="submit">Search</button>
</form>

</body>
</html>

const express = require("express");
const mysql = require("mysql2");
const bodyParser = require("body-parser");

const app = express();
app.use(bodyParser.urlencoded({ extended: true }));

// DB Connection
const db = mysql.createConnection({
  host: "localhost",
  user: "root",
  password: "",
  database: "eventdb"
});

db.connect(err => {
  if (err) throw err;
  console.log("MySQL Connected");
});

// Serve HTML
app.use(express.static("public"));

// REGISTER
app.post("/register", (req, res) => {
  let { regno, name, events } = req.body;

  if (!events) return res.send("Select at least one event");

  if (!Array.isArray(events)) events = [events];

  if (events.length > 3)
    return res.send("Error: Max 3 events allowed");

  let eventList = events.join(",");

  let sql = "INSERT INTO registrations VALUES (?, ?, ?)";

  db.query(sql, [regno, name, eventList], (err) => {
    if (err) {
      if (err.code === "ER_DUP_ENTRY")
        return res.send("Error: Register Number already exists");
      throw err;
    }
    res.send("Registration Successful");
  });
});

// SEARCH
app.get("/search", (req, res) => {
  let regno = req.query.regno;

  let sql = "SELECT * FROM registrations WHERE regno = ?";
  db.query(sql, [regno], (err, result) => {
    if (err) throw err;

    if (result.length === 0)
      return res.send("No record found");

    let r = result[0];

    res.send(`
      Reg No: ${r.regno}<br>
      Name: ${r.name}<br>
      Events: ${r.events}
    `);
  });
});

// START SERVER
app.listen(3000, () => {
  console.log("Server running on http://localhost:3000");
});
