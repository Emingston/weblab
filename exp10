<!DOCTYPE html>
<html>
<head>
  <title>AI Website</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1>AI Web Design</h1>
  <nav>
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section id="home">
  <h2>Welcome</h2>
  <p>This website is created using AI tools.</p>
  <button onclick="showMsg()">Click Me</button>
</section>

<section id="about">
  <h2>About</h2>
  <p>We use AI to design modern, fast, and responsive websites.</p>
</section>

<section id="services">
  <h2>Services</h2>
  <ul>
    <li>AI Website Design</li>
    <li>UI/UX Design</li>
    <li>Web Development</li>
  </ul>
</section>

<section id="contact">
  <h2>Contact</h2>
  <input type="text" placeholder="Your Name"><br><br>
  <input type="email" placeholder="Your Email"><br><br>
  <button onclick="submitForm()">Submit</button>
</section>

<script src="script.js"></script>
</body>
</html>

body {
  font-family: Arial;
  margin: 0;
  background: #f4f4f4;
  text-align: center;
}

header {
  background: #333;
  color: white;
  padding: 15px;
}

nav a {
  color: white;
  margin: 10px;
  text-decoration: none;
}

section {
  padding: 40px;
}

button {
  padding: 10px;
  background: #333;
  color: white;
  border: none;
}

@media (max-width: 600px) {
  nav a {
    display: block;
    margin: 5px;
  }
}

function showMsg() {
  alert("AI Generated Website!");
}

function submitForm() {
  alert("Form Submitted Successfully!");
}
