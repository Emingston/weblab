  "regno": "23CS101",
  "name": "Arun Kumar",
  "events": ["Coding Challenge", "Quiz Competition", "Web Design"]
}

const express = require("express");
const bodyParser = require("body-parser");
const { MongoClient } = require("mongodb");

const app = express();
app.use(bodyParser.urlencoded({ extended: true }));
app.use(express.static("public"));

const url = "mongodb://127.0.0.1:27017";
const client = new MongoClient(url);

let db;

// CONNECT DB
async function connectDB() {
  await client.connect();
  db = client.db("eventdb");
  console.log("MongoDB Connected");
}
connectDB();

// REGISTER
app.post("/register", async (req, res) => {
  let { regno, name, events } = req.body;

  if (!events) return res.send("Select at least one event");

  if (!Array.isArray(events)) events = [events];

  if (events.length > 3)
    return res.send("Error: Max 3 events allowed");

  const collection = db.collection("registrations");

  // CHECK DUPLICATE
  let existing = await collection.findOne({ regno });
  if (existing)
    return res.send("Error: Register Number already exists");

  await collection.insertOne({ regno, name, events });

  res.send("Registration Successful");
});

// SEARCH
app.get("/search", async (req, res) => {
  let regno = req.query.regno;

  const collection = db.collection("registrations");

  let result = await collection.findOne({ regno });

  if (!result) return res.send("No record found");

  res.send(`
    Register Number: ${result.regno}<br>
    Name: ${result.name}<br>
    Events: ${result.events.join(", ")}
  `);
});

// START SERVER
app.listen(3000, () => {
  console.log("Server running on http://localhost:3000");
});

